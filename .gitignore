# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-mobile/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — hiçbir env dosyası GitHub'a gitmesin
.env
.env.*
.env*.local

# Firebase SW: .env.local'den generate edilir (predev/prebuild)
/public/firebase-messaging-sw.js

# Firebase native credentials — her geliştirici kendi dosyasını Firebase Console'dan indirir
ios/App/App/GoogleService-Info.plist
android/app/google-services.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
